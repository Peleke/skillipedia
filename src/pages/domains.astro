---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const entries = await getCollection("entries");
const domainMap = new Map<string, number>();
for (const entry of entries) {
  domainMap.set(entry.data.domain, (domainMap.get(entry.data.domain) || 0) + 1);
}
const domains = [...domainMap.entries()].sort((a, b) => b[1] - a[1]);
---

<Base title="Domains — Skillipedia">
  <h1 class="mb-6 text-3xl font-bold">Domains</h1>
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {domains.map(([domain, count]) => (
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <div class="font-medium text-gray-900">{domain}</div>
        <div class="text-sm text-gray-500">{count} {count === 1 ? "entry" : "entries"}</div>
      </div>
    ))}
  </div>
</Base>
