---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const entries = await getCollection("entries");
const domainMap = new Map<string, number>();
for (const entry of entries) {
  domainMap.set(entry.data.domain, (domainMap.get(entry.data.domain) || 0) + 1);
}
const domains = [...domainMap.entries()].sort((a, b) => b[1] - a[1]);
---

<Base title="Domains — Skillipedia">
  <section class="mb-8 animate-fade-up">
    <h1 class="text-4xl font-bold tracking-tight text-ink-900 dark:text-parchment-50">Domains</h1>
    <p class="mt-3 text-lg text-ink-500 dark:text-parchment-400">{domains.length} domains in the knowledge base.</p>
  </section>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {domains.map(([domain, count]) => (
      <div class="group rounded-lg border border-parchment-300 bg-white p-5 shadow-card transition-all duration-200 hover:shadow-card-hover hover:-translate-y-0.5 dark:border-ink-700 dark:bg-ink-800">
        <div class="font-serif text-lg font-semibold text-ink-900 dark:text-parchment-100">{domain}</div>
        <div class="mt-1 font-mono text-sm text-ink-400 dark:text-parchment-600">
          {count} {count === 1 ? "entry" : "entries"}
        </div>
      </div>
    ))}
  </div>
</Base>
