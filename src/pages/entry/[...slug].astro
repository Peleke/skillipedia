---
import { marked } from "marked";
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import TypeBadge from "../../components/TypeBadge.astro";

export async function getStaticPaths() {
  const entries = await getCollection("entries");
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, "") },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;

// Extract the lead paragraph from the claim — everything before the first code block,
// table, or heading. The full content is shown below via <Content />.
const claimLead = data.claim
  .split(/```/)[0]                                  // before first code fence
  .split(/\n\s*\|/)[0]                              // before first table row
  .split(/\n\s*#{2,}/)[0]                           // before first sub-heading
  .replace(/\*\*([^*]+)\*\*/g, "$1")                // bold -> plain
  .replace(/`([^`]+)`/g, "<code>$1</code>")         // inline code -> html
  .replace(/\n{2,}/g, "</p><p>")                     // paragraph breaks
  .replace(/\n/g, " ")
  .replace(/\s{2,}/g, " ")
  .trim();
const claimHtml = `<p>${claimLead}</p>`;

const confidenceColor =
  data.confidence >= 0.8
    ? "text-falun-600 dark:text-falun-400"
    : data.confidence >= 0.5
      ? "text-parchment-700 dark:text-parchment-400"
      : "text-ink-400 dark:text-parchment-600";
---

<Base title={`${data.id} — Skillipedia`}>
  <!-- Back link -->
  <a href="/" class="inline-flex items-center gap-1.5 mb-6 font-mono text-sm text-ink-400 hover:text-falun-600 dark:text-parchment-500 dark:hover:text-falun-400 transition-colors">
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
    Back to entries
  </a>

  <div class="lg:flex lg:gap-10 animate-fade-up">
    <!-- Sidebar -->
    <aside class="mb-8 shrink-0 lg:mb-0 lg:w-72">
      <div class="rounded-lg border border-parchment-300 bg-white p-6 shadow-card dark:border-ink-700 dark:bg-ink-800">
        <div class="mb-4">
          <TypeBadge type={data.type} />
        </div>
        <dl class="space-y-4 text-sm">
          <div>
            <dt class="font-mono text-xs uppercase tracking-wider text-ink-400 dark:text-parchment-600">Domain</dt>
            <dd class="mt-0.5 font-medium text-ink-800 dark:text-parchment-200">{data.domain}</dd>
          </div>
          <div>
            <dt class="font-mono text-xs uppercase tracking-wider text-ink-400 dark:text-parchment-600">Confidence</dt>
            <dd class={`mt-0.5 font-mono font-semibold ${confidenceColor}`}>{(data.confidence * 100).toFixed(0)}%</dd>
          </div>
          <div>
            <dt class="font-mono text-xs uppercase tracking-wider text-ink-400 dark:text-parchment-600">Derivation</dt>
            <dd class="mt-0.5 font-medium text-ink-800 dark:text-parchment-200">{data.derivation}</dd>
          </div>
          <div>
            <dt class="font-mono text-xs uppercase tracking-wider text-ink-400 dark:text-parchment-600">Category</dt>
            <dd class="mt-0.5 font-medium text-ink-800 dark:text-parchment-200">{data.category}</dd>
          </div>
          {data.tags && data.tags.length > 0 && (
            <div>
              <dt class="font-mono text-xs uppercase tracking-wider text-ink-400 dark:text-parchment-600">Tags</dt>
              <dd class="mt-1.5 flex flex-wrap gap-1.5">
                {data.tags.map((tag) => (
                  <span class="rounded-md bg-parchment-200 px-2 py-0.5 font-mono text-xs text-ink-500 dark:bg-ink-700 dark:text-parchment-500">{tag}</span>
                ))}
              </dd>
            </div>
          )}
          <div>
            <dt class="font-mono text-xs uppercase tracking-wider text-ink-400 dark:text-parchment-600">Source</dt>
            <dd class="mt-0.5 font-medium text-ink-800 dark:text-parchment-200">{data.provenance.source_id || data.provenance.domain || "\u2014"}</dd>
          </div>
          <div>
            <dt class="font-mono text-xs uppercase tracking-wider text-ink-400 dark:text-parchment-600">Source Concepts</dt>
            <dd class="mt-0.5 font-medium text-ink-800 dark:text-parchment-200">{data.source_concepts.join(", ")}</dd>
          </div>
        </dl>
      </div>
    </aside>

    <!-- Content -->
    <article class="prose-norse flex-1 text-ink-700 dark:text-parchment-300">
      <div class="mb-6 font-serif text-xl leading-relaxed text-ink-600 dark:text-parchment-300" set:html={claimHtml} />
      <hr class="mb-6 border-parchment-300 dark:border-ink-700" />
      <Content />

      {/* Install instructions */}
      {data.type === "skill" && (data.metadata?.source_id || data.domain?.startsWith("skill:")) && (() => {
        const skillSlug = data.domain.replace("skill:", "");
        return (
        <aside class="mt-10 rounded-lg border border-parchment-300 bg-parchment-100 p-5 dark:border-ink-600 dark:bg-ink-800/60">
          <div class="mb-2 flex items-center gap-2">
            <svg class="h-4 w-4 text-falun-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="font-mono text-xs font-semibold uppercase tracking-wider text-falun-600 dark:text-falun-400">Use this skill</span>
          </div>

          {/* Option 1: Claude Code */}
          <div class="mb-4">
            <p class="mb-1.5 text-xs font-semibold uppercase tracking-wider text-ink-500 dark:text-parchment-500">Option 1 — Claude Code slash command</p>
            <p class="mb-2 text-sm text-ink-600 dark:text-parchment-400">Best when you're already in a Claude Code session and want to invoke the skill inline.</p>
            <div class="rounded-md bg-ink-900 px-4 py-3 font-mono text-sm text-parchment-200">
              <span class="select-none text-ink-500">/ </span>{skillSlug}
            </div>
            <p class="mt-1.5 text-xs text-ink-400 dark:text-parchment-600">
              Register the <a href={`https://github.com/Peleke/brunnr/tree/main/skills/${skillSlug}`} class="text-falun-600 underline decoration-falun-300 underline-offset-2 hover:decoration-falun-500 dark:text-falun-400 dark:decoration-falun-700 dark:hover:decoration-falun-400">skill directory</a> as a Claude Code custom slash command. See <a href="https://docs.anthropic.com/en/docs/agents-and-tools/claude-code/tutorials#create-custom-slash-commands" class="text-falun-600 underline decoration-falun-300 underline-offset-2 hover:decoration-falun-500 dark:text-falun-400 dark:decoration-falun-700 dark:hover:decoration-falun-400">custom slash commands</a> for setup.
            </p>
          </div>

          {/* Option 2: brunnr CLI */}
          <div>
            <p class="mb-1.5 text-xs font-semibold uppercase tracking-wider text-ink-500 dark:text-parchment-500">Option 2 — brunnr CLI</p>
            <p class="mb-2 text-sm text-ink-600 dark:text-parchment-400">Best for batch installs, CI pipelines, or managing skills across multiple projects.</p>
            <div class="space-y-1.5">
              <div class="rounded-md bg-ink-900 px-4 py-3 font-mono text-sm text-parchment-200">
                <span class="select-none text-ink-500">$ </span>pip install brunnr
              </div>
              <div class="rounded-md bg-ink-900 px-4 py-3 font-mono text-sm text-parchment-200">
                <span class="select-none text-ink-500">$ </span>brunnr install {skillSlug}
              </div>
            </div>
            <p class="mt-1.5 text-xs text-ink-400 dark:text-parchment-600">
              Installs the skill to <code class="rounded bg-ink-800 px-1 py-0.5 text-parchment-300">./skills/{skillSlug}/SKILL.md</code> in your project. By default, brunnr shows you the skill source for review before writing — use <code class="rounded bg-ink-800 px-1 py-0.5 text-parchment-300">--yes</code> to skip.
            </p>
          </div>
        </aside>
        );
      })()}
    </article>
  </div>
</Base>
