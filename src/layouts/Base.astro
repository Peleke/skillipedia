---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Skillipedia" } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500&display=swap"
      rel="stylesheet"
    />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem("theme");
        if (stored === "light") {
          document.documentElement.classList.remove("dark");
        } else if (stored === "dark") {
          document.documentElement.classList.add("dark");
        } else if (!window.matchMedia("(prefers-color-scheme: dark)").matches) {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-parchment-300 bg-parchment-50/80 backdrop-blur-md dark:border-ink-700 dark:bg-ink-900/80">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="group flex items-center gap-2">
          <span class="text-xl font-serif font-bold text-ink-900 dark:text-parchment-50 transition-colors group-hover:text-falun-600 dark:group-hover:text-falun-400">Skillipedia</span>
        </a>
        <div class="flex items-center gap-6">
          <!-- Nav links (hidden on mobile, shown on sm+) -->
          <div class="hidden sm:flex gap-6 text-sm font-medium">
            <a href="/" class="text-ink-500 hover:text-ink-900 dark:text-parchment-400 dark:hover:text-parchment-100 transition-colors">Home</a>
            <a href="/domains" class="text-ink-500 hover:text-ink-900 dark:text-parchment-400 dark:hover:text-parchment-100 transition-colors">Domains</a>
            <a href="/about" class="text-ink-500 hover:text-ink-900 dark:text-parchment-400 dark:hover:text-parchment-100 transition-colors">About</a>
          </div>
          <!-- Theme toggle -->
          <button
            id="theme-toggle"
            type="button"
            class="rounded-lg p-2 text-ink-400 hover:bg-parchment-200 hover:text-ink-700 dark:text-parchment-500 dark:hover:bg-ink-700 dark:hover:text-parchment-200 transition-colors"
            aria-label="Toggle theme"
          >
            <!-- Sun icon (shown in dark mode) -->
            <svg class="hidden dark:block h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <!-- Moon icon (shown in light mode) -->
            <svg class="block dark:hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            type="button"
            class="sm:hidden rounded-lg p-2 text-ink-400 hover:bg-parchment-200 dark:text-parchment-500 dark:hover:bg-ink-700 transition-colors"
            aria-label="Menu"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </nav>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden sm:hidden border-t border-parchment-300 dark:border-ink-700 px-6 py-3">
        <div class="flex flex-col gap-3 text-sm font-medium">
          <a href="/" class="text-ink-600 dark:text-parchment-300 py-1">Home</a>
          <a href="/domains" class="text-ink-600 dark:text-parchment-300 py-1">Domains</a>
          <a href="/about" class="text-ink-600 dark:text-parchment-300 py-1">About</a>
        </div>
      </div>
    </header>

    <!-- Main -->
    <main class="mx-auto w-full max-w-6xl flex-1 px-6 py-8">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-parchment-300 dark:border-ink-700 mt-auto">
      <div class="mx-auto max-w-6xl px-6 py-6">
        <div class="flex items-center justify-between text-sm text-ink-400 dark:text-parchment-600">
          <span class="font-mono text-xs">Skillipedia</span>
          <span class="font-mono text-xs">another encyclopedia nobody asked for</span>
        </div>
      </div>
    </footer>

    <!-- Theme toggle + mobile menu scripts -->
    <script is:inline>
      document.getElementById("theme-toggle").addEventListener("click", () => {
        const isDark = document.documentElement.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      });

      document.getElementById("mobile-menu-btn").addEventListener("click", () => {
        document.getElementById("mobile-menu").classList.toggle("hidden");
      });
    </script>
  </body>
</html>
