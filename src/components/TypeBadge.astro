---
interface Props {
  type: "skill" | "pattern" | "learning";
}

const { type } = Astro.props;

const colors = {
  skill: "bg-blue-100 text-blue-800",
  pattern: "bg-purple-100 text-purple-800",
  learning: "bg-green-100 text-green-800",
};
---

<span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${colors[type]}`}>
  {type}
</span>
