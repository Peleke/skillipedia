---
import TypeBadge from "./TypeBadge.astro";

interface Props {
  slug: string;
  id: string;
  type: "skill" | "pattern" | "learning";
  claim: string;
  domain: string;
  confidence: number;
  tags?: string[];
}

const { slug, id, type, claim, domain, confidence, tags } = Astro.props;
---

<a href={`/entry/${slug.replace(/\.mdx?$/, "")}`} class="block rounded-lg border border-gray-200 bg-white p-5 transition hover:border-gray-300 hover:shadow-sm">
  <div class="mb-2 flex items-center gap-2">
    <TypeBadge type={type} />
    <span class="text-xs text-gray-400">{domain}</span>
    <span class="ml-auto text-xs text-gray-400">{(confidence * 100).toFixed(0)}%</span>
  </div>
  <p class="text-sm leading-relaxed text-gray-700">{claim}</p>
  {tags && tags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1">
      {tags.map((tag) => (
        <span class="rounded bg-gray-100 px-1.5 py-0.5 text-xs text-gray-500">{tag}</span>
      ))}
    </div>
  )}
</a>
