---
import TypeBadge from "./TypeBadge.astro";

interface Props {
  slug: string;
  id: string;
  name?: string;
  type: "skill" | "pattern" | "learning";
  claim: string;
  domain: string;
  confidence: number;
  tags?: string[];
}

const { slug, id, name, type, claim, domain, confidence, tags } = Astro.props;

// Display name: use frontmatter name, or humanize slug
const displayName = name || slug.replace(/\.mdx?$/, "").replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());

// For cards: extract a clean text excerpt — strip markdown syntax, truncate
const plainClaim = claim
  .replace(/```[\s\S]*?(?:```|$)/g, "")  // remove fenced code blocks (incl. unclosed)
  .replace(/`{3}/g, "")                  // remove stray triple backticks
  .replace(/\|[^\n]+\|/g, "")           // remove table rows
  .replace(/\|-+/g, "")                 // remove table separators
  .replace(/#{1,6}\s+/g, "")            // remove headings
  .replace(/>\s+/g, "")                 // remove blockquotes
  .replace(/\*\*([^*]+)\*\*/g, "$1")    // bold -> plain
  .replace(/`([^`]+)`/g, "$1")          // inline code -> plain
  .replace(/`/g, "")                    // remove stray backticks
  .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1") // links -> text
  .replace(/\n{2,}/g, " ")              // collapse newlines
  .replace(/\n/g, " ")
  .replace(/\s{2,}/g, " ")
  .replace(/^\s*-\s+/gm, "- ")          // normalize list items
  .trim();
const excerpt = plainClaim.length > 140 ? plainClaim.slice(0, 137) + "..." : plainClaim;

const accentBar = {
  skill: "bg-falun-500 dark:bg-falun-600",
  pattern: "bg-parchment-500 dark:bg-parchment-600",
  learning: "bg-ink-400 dark:bg-ink-500",
};
---

<a
  href={`/entry/${slug.replace(/\.mdx?$/, "")}`}
  class="group block rounded-lg border border-parchment-300 bg-white shadow-card transition-all duration-200 hover:shadow-card-hover hover:-translate-y-0.5 dark:border-ink-700 dark:bg-ink-800"
  data-type={type}
  data-domain={domain}
  data-confidence={confidence}
>
  <!-- Accent bar -->
  <div class={`h-1 rounded-t-lg ${accentBar[type]}`}></div>

  <div class="p-5">
    <!-- Title -->
    <h3 class="mb-2 font-sans text-base font-semibold text-ink-900 dark:text-parchment-100 group-hover:text-falun-600 dark:group-hover:text-falun-400 transition-colors">
      {displayName}
    </h3>

    <!-- Meta row -->
    <div class="mb-3 flex items-center gap-2">
      <TypeBadge type={type} />
      <span class="rounded-md bg-parchment-200 px-1.5 py-0.5 font-mono text-[10px] text-ink-500 dark:bg-ink-700 dark:text-parchment-500">{domain}</span>
      <span class="ml-auto font-mono text-xs text-ink-400 dark:text-parchment-600">{(confidence * 100).toFixed(0)}%</span>
    </div>

    <!-- Claim excerpt -->
    <p class="font-serif text-sm leading-relaxed text-ink-600 dark:text-parchment-400">{excerpt}</p>

    <!-- Tags -->
    {tags && tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="rounded-md bg-parchment-200 px-2 py-0.5 font-mono text-xs text-ink-500 dark:bg-ink-700 dark:text-parchment-500">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>
